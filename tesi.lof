\contentsline {figure}{\numberline {2.27}{\ignorespaces c}}{27}{figure.caption.47}%
\contentsline {figure}{\numberline {2.28}{\ignorespaces Comparison between DEIMv2 and YOLOv12 in terms of accuracy, parameter count, and computational cost, highlighting the stronger overall efficiency of DEIMv2 across the considered model scales \cite {huang_real-time_2026,tian_yolov12_2025}.}}{28}{figure.caption.48}%
