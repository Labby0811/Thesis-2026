\contentsline {figure}{\numberline {2.3}{\ignorespaces Non-Maximum Suppression (NMS) is a post-processing technique used in object detection to eliminate redundant bounding boxes and retain only the most confident prediction for each detected object.}}{11}{figure.caption.18}%
\contentsline {figure}{\numberline {2.4}{\ignorespaces Different types of image segmentation}}{12}{figure.caption.19}%
\contentsline {figure}{\numberline {2.5}{\ignorespaces Visualization of k-means clustering applied to an image, where pixels are grouped into clusters based on their similarity and distance in the feature-space. Each cluster is represented by a different color, illustrating how the algorithm partitions the image into distinct regions.}}{13}{figure.caption.21}%
\contentsline {figure}{\numberline {2.6}{\ignorespaces Background subtraction example scheme.}}{14}{figure.caption.23}%
\contentsline {figure}{\numberline {2.7}{\ignorespaces Precision and Recall visualization, illustrating the concepts of true positives, false positives, and false negatives predictions compared to ground-truth annotations.}}{15}{figure.caption.25}%
\contentsline {figure}{\numberline {2.8}{\ignorespaces Visualization of the Intersection over Union (IoU) metric for image segmentation, illustrating the areas of true positives, false positives, and false negatives between a predicted segmentation mask and a ground-truth mask.}}{15}{figure.caption.27}%
\contentsline {figure}{\numberline {2.9}{\ignorespaces Visualization of the Area Under the Receiver Operating Characteristic Curve (AUROC) metric for image segmentation.}}{16}{figure.caption.28}%
\contentsline {figure}{\numberline {2.10}{\ignorespaces Schematic representation of a feedforward neural network with multiple hidden layers. Each layer applies a linear transformation followed by a non-linear activation, enabling progressively richer representations of the input.}}{17}{figure.caption.30}%
\contentsline {figure}{\numberline {2.11}{\ignorespaces Illustration of gradient descent over a loss surface. At each iteration, the parameters are updated in the direction of the negative gradient so as to reduce the loss.}}{17}{figure.caption.31}%
\contentsline {figure}{\numberline {2.12}{\ignorespaces Schematic representation of a deep neural network, where feature representations are learned across multiple layers of abstraction and not manually engineered.}}{18}{figure.caption.32}%
\contentsline {figure}{\numberline {2.13}{\ignorespaces Typical convolutional neural network architecture for visual processing, in which convolutional and downsampling stages progressively extract hierarchical features from the input image.}}{19}{figure.caption.33}%
\contentsline {figure}{\numberline {2.14}{\ignorespaces Receptive field comparison between CNNs and ViTs. While CNNs have a local receptive field that grows with depth, ViTs can capture global context from the very first layer due to their self-attention mechanism.}}{20}{figure.caption.34}%
\contentsline {figure}{\numberline {2.15}{\ignorespaces Schematic comparison of CNN and ViT architectures. The CNN (a) processes the image through a hierarchy of convolutional layers with local receptive fields, while the ViT (b) treats the image as a sequence of patches and applies self-attention to capture global dependencies.}}{20}{figure.caption.36}%
\contentsline {figure}{\numberline {2.16}{\ignorespaces Original DETR architecture.}}{21}{figure.caption.37}%
\contentsline {figure}{\numberline {2.17}{\ignorespaces RT-DETR architecture.}}{22}{figure.caption.38}%
\contentsline {figure}{\numberline {2.18}{\ignorespaces Hungarian matching in RT-DETR.}}{22}{figure.caption.39}%
\contentsline {figure}{\numberline {2.19}{\ignorespaces DEIMv2 architecture overview, illustrating the use of DINOv3 backbones and the Spatial Tuning Adapter (STA) to produce multi-scale features for detection \cite {huang_real-time_2026}.}}{24}{figure.caption.40}%
\contentsline {figure}{\numberline {2.20}{\ignorespaces Summary of DEIMv2 results across model scales, highlighting the balance between detection accuracy, latency, and parameter efficiency \cite {huang_real-time_2026}.}}{24}{figure.caption.41}%
\contentsline {figure}{\numberline {2.21}{\ignorespaces Area attention mechanism in YOLOv12 compared to traditional attention mechanisms.}}{25}{figure.caption.42}%
\contentsline {figure}{\numberline {2.22}{\ignorespaces YOLOv12 R-ELAN architecture overview, illustrating the skip connection mechanism to improve optimization stability in deeper attention-based models \cite {tian_yolov12_2025}.}}{25}{figure.caption.43}%
\contentsline {figure}{\numberline {2.23}{\ignorespaces Summary of YOLOv12 results on the COCO benchmark, highlighting its strong balance between detection accuracy and inference efficiency across model scales \cite {tian_yolov12_2025}.}}{26}{figure.caption.44}%
\contentsline {figure}{\numberline {2.24}{\ignorespaces c}}{26}{figure.caption.45}%
\contentsline {figure}{\numberline {2.25}{\ignorespaces EoMT mask annealing strategy, which progressively removes masked attention during training.}}{27}{figure.caption.46}%
